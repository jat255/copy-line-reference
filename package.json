{
  "name": "copy-line-reference",
  "displayName": "Copy Line Reference (Fork)",
  "description": "Copy reference to selected lines of code with a hotkey. Personal fork of reily/copy-line-reference.",
  "version": "0.0.6",
  "publisher": "josh-taillon",
  "author": {
    "name": "Josh Taillon",
    "email": "joshua.taillon@posit.co"
  },
  "fork": {
    "of": "reily.copy-line-reference",
    "originalAuthor": "reily (zhigang1992)",
    "source": "https://github.com/zhigang1992/copy-line-reference"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jat255/copy-line-reference"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "copyLineReference.copyReference",
        "title": "Copy Line Reference"
      },
      {
        "command": "copyLineReference.insertReferenceToSide",
        "title": "Insert Line Reference to Side Editor"
      }
    ],
    "keybindings": [
      {
        "command": "copyLineReference.copyReference",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorTextFocus"
      },
      {
        "command": "copyLineReference.insertReferenceToSide",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}